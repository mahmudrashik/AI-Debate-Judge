# ==========================================
# Causal XAI Debate Judge - .gitignore
# ==========================================

# ------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ------------------------------------------
# Python / FastAPI Backend
# ------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
.env/
pip-log.txt
pip-delete-this-directory.txt

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# ------------------------------------------
# Node.js / React / Vite Frontend
# ------------------------------------------
# Dependencies
frontend/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production build outputs
frontend/dist/
frontend/dist-ssr/
frontend/build/
dist/
build/

# Vite
*.local

# ------------------------------------------
# OS / Editor / IDE files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# VS Code
.vscode/
*.code-workspace

# IntelliJ / PyCharm
.idea/
*.iml

# ------------------------------------------
# Logs & Databases
# ------------------------------------------
*.log
*.sqlite3
*.db
